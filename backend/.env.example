# ============================================
# AI Job Hunter - Environment Variables
# ============================================
# IMPORTANT: Copy this file to .env and fill in your values
# NEVER commit .env to git. Only commit .env.example
# ============================================

# --- Azure OpenAI ---
# Get these from: Azure Portal → Azure OpenAI → Keys and Endpoint
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

# Deployment names (what you named your models in Azure OpenAI Studio)
AZURE_OPENAI_GPT4_DEPLOYMENT=gpt-4                # Used for: cover letters, question generation
AZURE_OPENAI_MINI_DEPLOYMENT=gpt-4o-mini          # Used for: answer evaluation (cheaper!)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002  # Used for: job matching

# --- Database ---
# Local PostgreSQL: postgresql://username:password@localhost:5432/dbname
# Azure SQL:        postgresql://username:password@your-server.postgres.database.azure.com:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/ai_job_hunter

# --- Supabase Auth ---
# Get these from: supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret    # Used to verify user tokens

# --- Azure Blob Storage ---
# Get from: Azure Portal → Storage Account → Access Keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER_NAME=resumes            # Container where PDFs are stored

# --- App Settings ---
APP_NAME=AI Job Hunter
APP_ENV=development                              # development | production
APP_SECRET_KEY=your-random-secret-key-here      # Used for session encryption
DEBUG=True                                       # Set to False in production

# --- CORS ---
# URLs allowed to call your API (your React app's URL)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Cost Control ---
# Maximum tokens per GPT-4 call (prevents runaway costs)
MAX_TOKENS_GPT4=2000
MAX_TOKENS_MINI=1000

# --- Audio ---
WHISPER_MODEL=base                              # tiny|base|small|medium|large (larger = better but slower)
MAX_AUDIO_SIZE_MB=25                            # Whisper's hard limit
