# frontend/.env.example
# ============================================
# Frontend Environment Variables
# ============================================
# IMPORTANT: In React/Vite, only variables starting with VITE_
# are accessible in your code. This is a security feature —
# it prevents accidentally exposing server secrets in frontend code.
#
# Access in code: import.meta.env.VITE_API_URL
# ============================================

# Your FastAPI backend URL
VITE_API_URL=http://localhost:8000/api/v1

# Supabase (for frontend auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# App name (shown in browser tab, headers)
VITE_APP_NAME=AI Job Hunter
